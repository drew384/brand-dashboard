# Twitter/X API
TWITTER_BEARER_TOKEN=your_bearer_token_here
# Get your numeric ID from https://tweeterid.com (enter your username)
TWITTER_USER_ID=your_numeric_user_id_here

# LinkedIn API — use ONE of these methods:

# Method A: 3-legged OAuth (recommended — works for all apps)
# Run the OAuth flow once, get token from redirect. Token expires in ~60 days.
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here

# Method B: Client credentials (requires LinkedIn approval — rarely granted)
# LINKEDIN_CLIENTID=your_client_id_here
# LINKEDIN_SECRET=your_client_secret_here
# LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here

# Server (local dev)
PORT=3000
